# The .git and bin/cache mount plugs make those SDK locations writable.
# Seed them on first launch; contents persist across refreshes.
# Re-run on every refresh — must be idempotent.

# Seed .git so Flutter's version detection works.
if [ ! -d "$SDK/.git/refs" ]; then
  SDK_VERSION=$(cat "$SDK/version" 2>/dev/null || echo "0.0.0")
  git init -b stable "$SDK" >/dev/null 2>&1
  GIT_DIR="$SDK/.git" GIT_WORK_TREE="$SDK" \
    GIT_AUTHOR_NAME=sdkcraft GIT_COMMITTER_NAME=sdkcraft \
    GIT_AUTHOR_EMAIL=noreply GIT_COMMITTER_EMAIL=noreply \
    git commit --allow-empty -q -m "v${SDK_VERSION}" 2>/dev/null
  GIT_DIR="$SDK/.git" git tag "$SDK_VERSION" 2>/dev/null || true
fi

# Seed bin/cache from the staging copy saved during setup-base.
# The mount plug replaced the original read-only cache with an empty
# writable dir; restore the pre-cached artifacts so Flutter works
# without network access.
# Always re-seed because Flutter's own scripts may move dart-sdk around
# (e.g. to dart-sdk.old) during config/precache operations.
CACHE_STAGING=/var/cache/flutter-sdk
if [ -d "$CACHE_STAGING" ] && [ ! -x "$SDK/bin/cache/dart-sdk/bin/dart" ]; then
  rm -rf "$SDK/bin/cache/dart-sdk" "$SDK/bin/cache/dart-sdk.old"
  cp -a "$CACHE_STAGING/." "$SDK/bin/cache/"
fi

# Seed flutter_tools .dart_tool from staging copy
DT_STAGING=/var/cache/flutter-dart-tool
if [ -d "$DT_STAGING" ] && [ ! -f "$SDK/packages/flutter_tools/.dart_tool/package_config.json" ]; then
  cp -a "$DT_STAGING/." "$SDK/packages/flutter_tools/.dart_tool/"
fi

# Pre-write engine.stamp to prevent Flutter from calling update_engine_version.sh
# which would otherwise try to resolve the engine version via git (may fail).
if [ -f "$SDK/bin/internal/engine.version" ]; then
  cat "$SDK/bin/internal/engine.version" > "$SDK/bin/cache/engine.stamp"
  echo "" > "$SDK/bin/cache/engine.realm"
fi

# Align flutter_tools.stamp with the current git HEAD so upgrade_flutter
# short-circuits and does not try to rebuild the tool (which would move
# dart-sdk and attempt a network download).
REVISION=$(git -C "$SDK" rev-parse HEAD 2>/dev/null || true)
if [ -n "$REVISION" ] && [ -f "$SDK/bin/cache/flutter_tools.snapshot" ]; then
  echo "${REVISION}:" > "$SDK/bin/cache/flutter_tools.stamp"
fi

flutter config --no-analytics 2>/dev/null || true
dart --disable-analytics 2>/dev/null || true
